# Local development (docker-compose MongoDB, single-node replica set "rs0").
# Ignored in AWS when SECRET_NAME is set. In AWS this is a MongoDB
# connection string too (e.g. mongodb+srv://... for MongoDB Atlas).
DATABASE_URL="mongodb://localhost:27017/j7website_short_url?replicaSet=rs0"

# Public root URL of this API (no trailing "/r") used to build the "shortUrl"
# field in responses as "${BASE_URL}/r/{code}", e.g. https://api.example.com
BASE_URL="http://localhost:3000"

# Uncomment and change if port 3000 is already in use on your machine
# (src/main.ts falls back to 3000 if this is unset). Keep BASE_URL in sync.
# PORT=3001

# Friendly name (not full ARN) of the Secrets Manager secret holding MongoDB
# credentials. When set, it takes precedence over DATABASE_URL (see
# src/config/secrets.service.ts). Leave unset (not empty string) for local
# development — the schema treats "" as invalid, only a missing key is
# treated as "not set".
# SECRET_NAME=

NODE_ENV="development"

# NOTE: AWS_REGION is intentionally not set here — it is a Lambda-reserved
# environment variable injected automatically at runtime. Locally, the AWS SDK
# falls back to your configured profile/region.
